<table class="table">
  <thead>
    <tr>
      <th>Nama</th>
      <th>Email</th>
      <th>Aksi</th>
    </tr>
  </thead>

  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td>
          <div class="d-flex gap-2">
            <%= link_to "Show", user_path(user), class: "btn btn-info btn-sm" %>
            <%= link_to "Edit", edit_user_path(user), class: "btn btn-warning btn-sm" %>

            <%= button_to "Delete", user_path(user),
                  method: :delete,
                  form: { class: "d-inline" },
                  class: "btn btn-danger btn-sm" %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
