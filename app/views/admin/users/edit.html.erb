<h3>Edit User</h3>

<%= form_with(model: [:admin, @user], local: true) do |f| %>

  <div class="mb-3">
    <%= f.label :name %>
    <%= f.text_field :name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :email %>
    <%= f.email_field :email, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :role %>
    <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] }, {}, class: "form-control" %>
  </div>

  <%= f.submit "Update", class: "btn btn-primary" %>

<% end %>
