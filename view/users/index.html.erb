<h1>Daftar Users</h1>

<table border="1" cellpadding="10">
  <thead>
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Aksi</th>
    </tr>
  </thead>

  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td>
          <%= link_to "Show", user_path(user), class: "btn btn-info btn-sm" %>

          <%= button_to "Hapus", user_path(user),
              method: :delete,
              data: { confirm: "Yakin?" },
              class: "btn btn-danger btn-sm" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
